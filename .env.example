# ═══════════════════════════════════════════════════════════
#  La Madrina Forrajería — Variables de entorno
#  1. Copiá este archivo como `.env`
#  2. Completá los valores reales
#  3. NUNCA subas `.env` a Git (ya está en .gitignore)
# ═══════════════════════════════════════════════════════════

# ── URL pública del sitio ─────────────────────────────────
# En desarrollo: http://localhost:3000
# En producción: https://tudominio.com.ar (sin slash final)
# Mercado Pago usa esta URL para el webhook y los back_urls.
BASE_URL=http://localhost:3000

# Puerto (opcional, default 3000)
PORT=3000

# Nombre del negocio (aparece en emails)
BUSINESS_NAME=La Madrina Forrajería

# ── Mercado Pago ──────────────────────────────────────────
# Obtener en: https://www.mercadopago.com.ar/developers/panel/app
#   → elegí o creá una aplicación
#   → "Credenciales de producción" para cobrar de verdad
#   → "Credenciales de prueba" para testear sin cobrar
# El token de producción empieza con APP_USR-
# El token de prueba empieza con TEST-
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx

# ── Email del vendedor ────────────────────────────────────
# Dirección donde llegan los avisos de cada pedido
SELLER_EMAIL=tu_email@ejemplo.com

# ── SMTP (para enviar emails) ─────────────────────────────
# Para Gmail: generá una "Contraseña de aplicación" en
# https://myaccount.google.com/apppasswords
# (requiere tener activada la verificación en 2 pasos)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# ── Datos bancarios (para pagos por transferencia) ────────
# Se muestran al cliente cuando elige "Transferencia bancaria"
# y se envían automáticamente por email.
BANK_CBU=0000000000000000000000
BANK_ALIAS=la.madrina.forraje
BANK_HOLDER=Nombre Apellido del Titular
BANK_BANK=Banco Galicia
BANK_CUIT=20-12345678-9

# ── Supabase (para el stock) ──────────────────────────────
# Obtener en: https://supabase.com → tu proyecto → Settings → API
# Usá la "service_role key" (NUNCA la anon key en el servidor)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXXXXXX

# Clave secreta para que el Google Sheet pueda actualizar el stock.
# Poné cualquier cadena larga y aleatoria (ej: generada en https://randomkeygen.com)
SYNC_SECRET=una-clave-secreta-muy-larga-y-aleatoria
